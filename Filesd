    private func appleMapsStyleBottomPanel(totalHeight: CGFloat) -> some View {
        let collapsedHeight = 78.0
        let mediumHeight = max(250, totalHeight * 0.31)
        let largeHeight = max(430, totalHeight * 0.64)

        let panelHeight: CGFloat
        switch panelDetent {
        case .collapsed:
            panelHeight = collapsedHeight
        case .medium:
            panelHeight = mediumHeight
        case .large:
            panelHeight = largeHeight
        }

        return VStack(spacing: 0) {
            Capsule()
                .fill(.white.opacity(0.24))
                .frame(width: 34, height: 5)
                .padding(.top, 8)
                .padding(.bottom, 8)
                .frame(maxWidth: .infinity)
                .contentShape(Rectangle())
                .gesture(
                    DragGesture(minimumDistance: 8)
                        .onEnded { value in
                            let drag = value.translation.height
                            let predicted = value.predictedEndTranslation.height
                            let snap = CGFloat(bottomSheetSnapThreshold)

                            let moveUp = drag < -snap || predicted < -(snap * 1.5)
                            let moveDown = drag > snap || predicted > (snap * 1.5)

                            let target: MapBottomPanelDetent

                            if moveUp {
                                switch panelDetent {
                                case .collapsed: target = .medium
                                case .medium: target = .large
                                case .large: target = .large
                                }
                            } else if moveDown {
                                switch panelDetent {
                                case .large: target = .medium
                                case .medium: target = .collapsed
                                case .collapsed: target = .collapsed
                                }
                            } else {
                                target = panelDetent
                            }

                            withAnimation(
                                .interactiveSpring(
                                    response: bottomSheetSpringResponse,
                                    dampingFraction: bottomSheetSpringDamping,
                                    blendDuration: 0.12
                                )
                            ) {
                                panelDetent = target
                            }
                        }
                )

            bottomQuickZoomRow

            if panelDetent != .collapsed {
                expandedPanelContent
            }

            Spacer(minLength: 0)
        }
        .frame(maxWidth: .infinity)
        .frame(height: panelHeight, alignment: .top)
        .background(
            RoundedRectangle(cornerRadius: 30, style: .continuous)
                .fill(.black.opacity(0.86))
        )
        .overlay(
            RoundedRectangle(cornerRadius: 30, style: .continuous)
                .strokeBorder(.white.opacity(0.07), lineWidth: 1)
        )
        .shadow(color: .black.opacity(0.22), radius: 18, y: 4)
        .padding(.horizontal, 6)
        .padding(.bottom, 2)
    }

